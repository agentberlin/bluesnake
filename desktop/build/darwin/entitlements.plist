<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the notarized macOS build (release.yml).

  Deliberately minimal. The WebKit JS engine runs in a separate, system-signed
  WebContent process (not the app), and the embedded CLI is signed with the same
  Team ID under the hardened runtime, so the app needs no library-validation or
  unsigned-memory exceptions. allow-jit is the one entitlement Wails webview apps
  commonly want. Add more only if notarytool or a runtime crash demands it.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
